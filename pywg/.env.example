# Telegram Bot Token
# Получить: https://t.me/BotFather → /newbot
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# WireGuard Easy API пароль
WG_PASSWORD=YOUR_WG_PASSWORD_HERE

# Базовый URL API WireGuard Easy
WG_API_BASE=http://localhost:51821/api

# Username администратора (без @)
ADMIN_USERNAME=YOUR_ADMIN_USERNAME

# Максимум конфигов на пользователя
MAX_CONFIGS_PER_USER=4

# Chat ID администратора для уведомлений от awg_monitor.py
# Узнать свой ID: написать боту /start, затем открыть
# https://api.telegram.org/bot<BOT_TOKEN>/getUpdates и найти "chat":{"id":...}
TG_ADMIN_CHAT_ID=YOUR_CHAT_ID_HERE

# Прокси для Telegram API (если прямой доступ заблокирован)
# Поддерживаются: socks5://host:port, http://host:port
# Пример: HTTP_PROXY=socks5://10.30.0.1:1080
HTTP_PROXY=

# Webhook (если не задан — используется polling)
# Домен должен иметь SSL-сертификат
WEBHOOK_URL=https://bot.YOUR_DOMAIN_HERE
WEBHOOK_PORT=8443
# Секрет для верификации запросов от Telegram (любая случайная строка)
WEBHOOK_SECRET=replace_with_random_secret

# SmartVPN настройки (если используется wg-smart / vdsina хаб)
SMART_ENDPOINT=YOUR_HUB_DOMAIN_OR_IP:51830
SMART_SERVER_IP=10.30.0.1
SMART_DNS=10.30.0.1
SMART_CONF=/etc/wireguard/wg-smart.conf
SMART_DIR=/etc/wireguard/smart

# Путь к servers.conf для awg_monitor.py
SERVERS_CONF=/etc/amnezia/amneziawg/servers.conf
