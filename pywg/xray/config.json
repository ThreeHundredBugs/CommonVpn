{
  "log": { "loglevel": "warning" },
  "inbounds": [
    { "tag": "socks-local", "listen": "127.0.0.1", "port": 1080, "protocol": "socks", "settings": { "udp": true } },
    { "tag": "http-local", "listen": "127.0.0.1", "port": 1081, "protocol": "http" },
    { "tag": "socks-smart", "listen": "10.30.0.1", "port": 1080, "protocol": "socks", "settings": { "udp": true } },
    { "tag": "http-smart", "listen": "10.30.0.1", "port": 1081, "protocol": "http" }
  ],
  "outbounds": [
    {
      "tag": "vless-out",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "YOUR_EXIT_SERVER_IP",
            "port": 2053,
            "users": [
              { "id": "YOUR_XRAY_UUID", "encryption": "none", "flow": "xtls-rprx-vision" }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.microsoft.com",
          "fingerprint": "firefox",
          "publicKey": "YOUR_XRAY_PUBLIC_KEY",
          "shortId": "YOUR_XRAY_SHORT_ID",
          "spiderX": "/"
        }
      }
    },
    { "tag": "direct", "protocol": "freedom" },
    { "tag": "block", "protocol": "blackhole" }
  ],
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "outboundTag": "direct", "ip": ["geoip:private"] },
      { "type": "field", "outboundTag": "vless-out", "network": "tcp,udp" }
    ]
  }
}
